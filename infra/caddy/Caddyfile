{
    email {$ACME_EMAIL:admin@officehub.local}
}

# Development defaults to plain HTTP on localhost.
# In production, set ENVIRONMENT=production and SITE_ADDRESS to the public hostname.
# Caddy will then obtain and renew Let's Encrypt certificates automatically.
{$SITE_ADDRESS:http://localhost} {
    @api path /api /api/*
    handle @api {
        reverse_proxy {$BACKEND_UPSTREAM:localhost:8000}
    }

    handle {
        reverse_proxy {$FRONTEND_UPSTREAM:localhost:3000}
    }
}
